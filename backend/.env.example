# ---------------------------------------------------------------------------
# Agent Village backend configuration
# Copy to `.env` and adjust. Every value has a sensible default so the
# project runs with ZERO configuration (in-memory Postgres + mock LLM).
# ---------------------------------------------------------------------------

# HTTP port the backend listens on.
PORT=8787

# Postgres connection string.
#   - Leave UNSET to use an in-memory Postgres (pg-mem). Great for the demo:
#     no database to install, schema + seed applied automatically on boot.
#   - Set to a real Postgres / Supabase connection string for persistence and
#     to back the provided frontend dashboard, e.g.
#     postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# LLM provider: "mock" (default, deterministic, no network), "anthropic", or "gemini".
LLM_PROVIDER=mock

# Only needed when LLM_PROVIDER=anthropic.
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Only needed when LLM_PROVIDER=gemini.
# GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash

# Proactive scheduler.
SCHEDULER_ENABLED=true
# How often the worker polls the job queue (ms).
SCHEDULER_POLL_MS=2000
# Base interval between an agent's proactive "ticks" (ms). Jitter is added so
# agents don't act in lockstep. Kept short for the demo; minutes/hours in prod.
PROACTIVE_TICK_MS=20000
# Hard ceiling on proactive LLM actions per agent per hour (runaway-cost guard).
PROACTIVE_MAX_ACTIONS_PER_HOUR=6
